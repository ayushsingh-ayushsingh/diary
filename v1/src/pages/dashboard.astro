---
import Main from "@/layouts/main.astro"
import { db } from "@/db"
import { blog, author } from "@/db/schema"
import { eq, desc } from "drizzle-orm"
import { auth } from "@/lib/auth"
import { buttonVariants } from "@/components/ui/button"
import { SettingsModal } from "@/components/blocks/settings-modal"
import { cn } from "@/lib/utils"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (!session) return Astro.redirect("/")

const userAuthor = await db.query.author.findFirst({
  where: eq(author.userId, session.user.id),
})

let blogsList: (typeof blog.$inferSelect)[] = []
if (userAuthor) {
  blogsList = await db.query.blog.findMany({
    where: eq(blog.authorId, userAuthor.id),
    orderBy: [desc(blog.createdAt)],
  })
}

const publicBlogs = blogsList.filter((b) => b.visibility === "public")
const unlistedBlogs = blogsList.filter((b) => b.visibility === "unlisted")
const privateBlogs = blogsList.filter((b) => b.visibility === "private")
---

<Main title="Dashboard">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div
      class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-center"
    >
      <div>
        <h1 class="text-4xl font-bold tracking-tight">Your Dashboard</h1>
        <p class="mt-1 text-muted-foreground">
          Manage your blogs and profile settings.
        </p>
      </div>
      <div class="flex gap-2">
        <SettingsModal
          client:load
          currentName={session.user.name || ""}
          currentImage={session.user.image ?? null}
        />
        <a href="/editor" class={cn(buttonVariants({ variant: "default" }))}>
          Create New Blog
        </a>
      </div>
    </div>

    <div class="space-y-12">
      <section>
        <h2 class="mb-4 border-b pb-2 text-2xl font-semibold">
          Public Blogs ({publicBlogs.length})
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            publicBlogs.map((b) => (
              <div class="flex flex-col justify-between rounded-lg border bg-card p-4 shadow-sm">
                <div>
                  <h3 class="mb-2 truncate text-lg leading-tight font-medium">
                    {b.title || "Untitled"}
                  </h3>
                  <p class="mb-4 text-xs text-muted-foreground">
                    {new Date(b.createdAt).toLocaleDateString()}
                  </p>
                </div>
                <div class="mt-auto flex gap-2">
                  <a
                    href={`/${b.slug}`}
                    class={cn(
                      buttonVariants({ variant: "outline", size: "sm" }),
                      "flex-1"
                    )}
                  >
                    View
                  </a>
                  <a
                    href={`/editor?id=${b.id}`}
                    class={cn(buttonVariants({ size: "sm" }), "flex-1")}
                  >
                    Edit
                  </a>
                </div>
              </div>
            ))
          }
          {
            publicBlogs.length === 0 && (
              <p class="text-sm text-muted-foreground">No public blogs yet.</p>
            )
          }
        </div>
      </section>

      <section>
        <h2 class="mb-4 border-b pb-2 text-2xl font-semibold">
          Unlisted Blogs ({unlistedBlogs.length})
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            unlistedBlogs.map((b) => (
              <div class="flex flex-col justify-between rounded-lg border bg-card p-4 shadow-sm">
                <div>
                  <h3 class="mb-2 truncate text-lg leading-tight font-medium">
                    {b.title || "Untitled"}
                  </h3>
                  <p class="mb-4 text-xs text-muted-foreground">
                    {new Date(b.createdAt).toLocaleDateString()}
                  </p>
                </div>
                <div class="mt-auto flex gap-2">
                  <a
                    href={`/${b.slug}`}
                    class={cn(
                      buttonVariants({ variant: "outline", size: "sm" }),
                      "flex-1"
                    )}
                  >
                    View
                  </a>
                  <a
                    href={`/editor?id=${b.id}`}
                    class={cn(buttonVariants({ size: "sm" }), "flex-1")}
                  >
                    Edit
                  </a>
                </div>
              </div>
            ))
          }
          {
            unlistedBlogs.length === 0 && (
              <p class="text-sm text-muted-foreground">
                No unlisted blogs yet.
              </p>
            )
          }
        </div>
      </section>

      <section>
        <h2 class="mb-4 border-b pb-2 text-2xl font-semibold">
          Private Blogs ({privateBlogs.length})
        </h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            privateBlogs.map((b) => (
              <div class="flex flex-col justify-between rounded-lg border bg-card p-4 shadow-sm">
                <div>
                  <h3 class="mb-2 truncate text-lg leading-tight font-medium">
                    {b.title || "Untitled"}
                  </h3>
                  <p class="mb-4 text-xs text-muted-foreground">
                    {new Date(b.createdAt).toLocaleDateString()}
                  </p>
                </div>
                <div class="mt-auto flex gap-2">
                  <a
                    href={`/${b.slug}`}
                    class={cn(
                      buttonVariants({ variant: "outline", size: "sm" }),
                      "flex-1"
                    )}
                  >
                    View
                  </a>
                  <a
                    href={`/editor?id=${b.id}`}
                    class={cn(buttonVariants({ size: "sm" }), "flex-1")}
                  >
                    Edit
                  </a>
                </div>
              </div>
            ))
          }
          {
            privateBlogs.length === 0 && (
              <p class="text-sm text-muted-foreground">No private blogs yet.</p>
            )
          }
        </div>
      </section>
    </div>
  </div>
</Main>
